# =============================================================================
# THREAT REPORTING SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# FLASK CONFIGURATION
# -----------------------------------------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=generate-a-long-random-string-here-use-secrets.token_hex(32)

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# For development (SQLite):
DATABASE_URL=sqlite:///database.db

# For production (PostgreSQL - recommended):
# DATABASE_URL=postgresql://username:password@localhost:5432/threat_reporting
# For Heroku, this is auto-set by Heroku Postgres addon

# -----------------------------------------------------------------------------
# TWILIO SMS CONFIGURATION (Required for OTP)
# -----------------------------------------------------------------------------
# Get these from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890  # Your Twilio phone number (E.164 format)

# =======================================================================
# EMAIL CONFIGURATION (Gmail recommended) - IMPORTANT SETUP REQUIRED
# =======================================================================
# Gmail App Password Setup Instructions:
# 1. Go to Google Account: https://myaccount.google.com/security
# 2. Enable "2-Step Verification" if not already enabled
# 3. Go to App Passwords: https://myaccount.google.com/apppasswords
# 4. Select "Mail" and "Windows Computer" (or your device)
# 5. Generate password - you'll get a 16-character password like: abcd efgh ijkl mnop
# 6. Use that 16-character password below (WITHOUT spaces)
# 7. IMPORTANT: Do NOT use your regular Gmail password!

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=sathwikgoundla3@gmail.com
MAIL_PASSWORD=vowd uapp tvdw ojsz
MAIL_DEFAULT_SENDER=sathwikgoundla3@gmail.com

# Alternative SMTP providers (if not using Gmail):
# ---
# For Outlook/Hotmail:
#   MAIL_SERVER=smtp-mail.outlook.com
#   MAIL_PORT=587
#   MAIL_USERNAME=your-email@outlook.com
#   MAIL_PASSWORD=your-outlook-password
#
# For SendGrid:
#   MAIL_SERVER=smtp.sendgrid.net
#   MAIL_PORT=587
#   MAIL_USERNAME=apikey
#   MAIL_PASSWORD=your-sendgrid-api-key
#
# For AWS SES:
#   MAIL_SERVER=email-smtp.region.amazonaws.com
#   MAIL_PORT=587
#   MAIL_USERNAME=your-ses-smtp-username
#   MAIL_PASSWORD=your-ses-smtp-password

# ====================================================================
# USER ROLE ASSIGNMENT
# ====================================================================
# To assign users as Admin or Manager, use their phone numbers
# Format: E.164 (includes country code)

# Admin: Single phone number
ADMIN_PHONE=+919949258081

# Managers: Comma-separated list of phone numbers
MANAGER_PHONES=+919949258081,+919398018154

# All other phone numbers will be automatically assigned 'user' role

# ====================================================================
# RATE LIMITING (Prevents abuse and spam)
# ====================================================================
# For development (in-memory, single server):
RATELIMIT_STORAGE_URL=memory://

# For production with Redis (recommended for multiple servers):
# RATELIMIT_STORAGE_URL=redis://localhost:6379
# RATELIMIT_STORAGE_URL=redis://:password@localhost:6379

# ====================================================================
# OPTIONAL: ADVANCED SETTINGS
# ====================================================================

# Session lifetime in seconds (default: 86400 = 1 day)
# PERMANENT_SESSION_LIFETIME=86400

# Maximum file upload size (default: 52428800 = 50MB)
# MAX_CONTENT_LENGTH=52428800

# Upload folder (default: uploads)
# UPLOAD_FOLDER=uploads

# PostgreSQL Connection Timeout (default: 30 seconds)
# DB_CONNECT_TIMEOUT=30
